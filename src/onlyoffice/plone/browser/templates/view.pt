  <!-- The document name and metadata are already shown in the breadcrumb and
       in the ONLYOFFICE editor header. Drop the duplicate page title here and
       suppress the byline via a no-op viewlet (see viewlets.py / the viewlet
       override in configure.zcml). -->
  <metal:title fill-slot="content-title" />

  <metal:block fill-slot="content-core">
    <div class="onlyoffice-download-bar"
         tal:condition="context/file | nothing"
         style="display:flex; justify-content:flex-end; margin-bottom:.75rem;"
    >
      <button type="button"
              class="btn btn-primary"
              onclick="onlyofficeDownload()"
              title="Download the document as it is now in the editor"
              i18n:attributes="title"
      >
        <svg xmlns="http://www.w3.org/2000/svg"
             width="16"
             height="16"
             fill="currentColor"
             viewBox="0 0 16 16"
             aria-hidden="true"
             style="vertical-align:-2px; margin-right:.4rem;"
        >
          <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z" />
          <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z" />
        </svg>
        <span i18n:translate="">Download</span>
      </button>
    </div>
    <div id="onlyofficeEditor"></div>
    <div id="onlyofficeErrorNotAccessible"
         style="display:none;"
         i18n:translate=""
    >DocumentServer not accessible.</div>
    <div id="onlyofficeErrorNotSupportedVersion"
         style="display:none;"
         i18n:translate=""
    >Not supported version DocumentServer.</div>
    <div id="onlyofficeErrorNotSupportedVersionForm"
         style="display:none;"
         i18n:translate=""
    >Please update ONLYOFFICE Docs to version 7.0 to work on fillable forms
      online.</div>

    <a class="pat-plone-modal"
       id="insert-dialog-onlyoffice-triger"
       href="#insert-dialog-onlyoffice"
       style="display: none;"
       data-pat-plone-modal="width: 600px;"
    >
    </a>
    <div id="insert-dialog-onlyoffice"
         style="display: none"
         i18n:domain="plone"
    >
      <div class="linkModal">
        <h1 i18n:translate="label_select_content_item">Select a content item</h1>
        <div class="mb-3 field fieldname-form.widgets.fileTitle widget-mode-input False"
             id="fileTitle"
        >
          <label>
            <label class="form-label"
                   for="onlyoffice-file-title"
                   i18n:translate="label_title"
            >Title</label>
            <span class="required"
                  title="Required"
                  i18n:ignore-attributes="title"
            ></span>
          </label>
          <input class="form-control text-widget required textline-field"
                 id="onlyoffice-file-title"
                 name="onlyoffice.file.title"
                 required="required"
                 type="text"
          />
          <div class="fieldErrorBox"
               style="display: none"
               i18n:domain="onlyoffice.plone"
          >
            <em class="invalid-feedback"
                i18n:translate=""
            >Please fill out this field.</em>
          </div>
        </div>
        <div id="relatedItems"></div>
        <div class="formControls">
          <input class="btn submit-widget button-field btn-secondary"
                 name="cancel"
                 type="submit"
                 value="Cancel"
                 i18n:attributes="value label_cancel;"
          />
          <input class="btn submit-widget button-field btn-primary"
                 name="ok"
                 type="submit"
                 value="Ok"
                 i18n:attributes="value label_ok;"
          />
        </div>
      </div>
    </div>

    <script src="${view/docUrl}web-apps/apps/api/documents/api.js?shardkey=${view/documentKey}"
            type="text/javascript"
    ></script>
    <script language="javascript"
            type="text/javascript"
    >
      var docEditor;
      var config = ${view/editorCfg}
      var saveAs = ${view/saveAs}
      var demo = ${view/demo}
      config.width = "100%";
      config.height = "100%";

      // Make the editor fill the browser window from where it starts down to
      // the bottom of the page, instead of a fixed 600px that leaves blank
      // space below it. Re-applied on resize so it tracks the viewport.
      function resizeOnlyofficeEditor() {
        var el = document.querySelector('iframe[name="frameEditor"]') ||
                 document.getElementById("onlyofficeEditor");
        if (!el) { return; }
        var top = el.getBoundingClientRect().top + window.pageYOffset;
        el.style.height = Math.max(400, window.innerHeight - top) + "px";
      }
      window.addEventListener("resize", resizeOnlyofficeEditor);
      window.addEventListener("load", function () {
        setTimeout(resizeOnlyofficeEditor, 100);
      });

      var baseModalDialog = {
        createDialod: function (selectableTypes, titleValue = null) {
          var modalDialog = $("#insert-dialog-onlyoffice-triger").patPloneModal().data("pattern-plone-modal");

          var relatedItemsOptions = ${view/relatedItemsOptions}
          relatedItemsOptions.selectableTypes = selectableTypes;
          relatedItemsOptions.maximumSelectionSize = 1;

          var relatedItems = document.createElement("input");
          relatedItems.type = "text";
          relatedItems.className = "pat-relateditems";
          relatedItems.setAttribute("data-pat-relateditems", JSON.stringify(relatedItemsOptions));

          document.getElementById('relatedItems').innerHTML = "";
          document.getElementById('relatedItems').append(relatedItems);

          modalDialog.show();

          if(titleValue) {
            modalDialog.$modal.find("div#fileTitle").show();
            modalDialog.$modal.find("input#onlyoffice-file-title").val(titleValue);
          }

          modalDialog.$modal.find("div.pattern-modal-buttons input[name='cancel']").on("click", function () {
            modalDialog.hide();
          });

          return modalDialog;
        },
        setSubmitRequest: function (modalDialog, submitRequest) {
          modalDialog.$modal.find("div.pattern-modal-buttons input[name='ok']").on("click", submitRequest);
        }
      };

      var requestInsert = function (modalDialog, docEditorEvent, command = null) {
        var selectedItems = modalDialog.$modal.find("div.pat-relateditems").select2("data");
        var selectedUIDs = (selectedItems || []).map(
          function (el) {
            return el.UID;
          }
        );

        var request = new XMLHttpRequest();
        request.open("POST", "${context/absolute_url}/onlyoffice-insert", false);
        request.setRequestHeader("x-csrf-token", "${view/token}");
        request.send(JSON.stringify({
          command: command,
          UIDs: selectedUIDs
        }));

        if (request.status == 200) {
          var insertObjects = JSON.parse(request.responseText);

          // bug https://bugzilla.onlyoffice.com/show_bug.cgi?id=50683
          // insertObjects.forEach((insertObject) => {
          //    docEditorEvent(insertObject);
          // });

          docEditorEvent(insertObjects[0]);
          modalDialog.hide();
        }
      };

      var onAppReady = function () {
        if (demo) {
          docEditor.showMessage(demo.message);
        }
      };

      var onRequestInsertImage = function (event) {
        var insertImageDialog = baseModalDialog.createDialod(["Image"]);
        baseModalDialog.setSubmitRequest(insertImageDialog, function () {
          requestInsert(insertImageDialog, docEditor.insertImage, event.data.c);
        });
      };

      var onRequestCompareFile = function () {
        var insertFileDialog = baseModalDialog.createDialod(["File"]);
        baseModalDialog.setSubmitRequest(insertFileDialog, function () {
          requestInsert(insertFileDialog, docEditor.setRevisedFile);
        });
      };

      var onRequestMailMergeRecipients = function () {
        var insertFileDialog = baseModalDialog.createDialod(["File"]);
        baseModalDialog.setSubmitRequest(insertFileDialog, function () {
          requestInsert(insertFileDialog, docEditor.setMailMergeRecipients);
        });
      };

      var onRequestSaveAs = function (event) {
        var url = event.data.url;
        var fileTitle = event.data.title.substring(0, event.data.title.lastIndexOf("."));
        var fileType = event.data.fileType ? event.data.fileType : event.data.title.split(".").pop();

        var saveAsDialog = baseModalDialog.createDialod(["Folder"], fileTitle);
        saveAsDialog.$modal.find(".plone-modal-title").text(saveAs.title);
        saveAsDialog.$modal.find("div.pat-relateditems").append("<div class='formHelp'>" + saveAs.helpTitle + " </div>");

        baseModalDialog.setSubmitRequest(saveAsDialog, function () {
          var selectedItems = saveAsDialog.$modal.find("div.pat-relateditems").select2("data");
          var selectedUIDs = (selectedItems || []).map(
            function (el) {
              return el.UID;
            }
          );

          var fileTitle = saveAsDialog.$modal.find("input#onlyoffice-file-title").val();

          if (!fileTitle) {
            saveAsDialog.loading.hide();
            saveAsDialog.$modal.find("div#fileTitle").addClass("error");
            saveAsDialog.$modal.find("div#fileTitle div.fieldErrorBox").show();
            return;
          } else {
            saveAsDialog.$modal.find("div#fileTitle div.fieldErrorBox").hide();
          }

          var request = new XMLHttpRequest();
          request.open("POST", "${context/absolute_url}/onlyoffice-save-as", false);
          request.setRequestHeader("x-csrf-token", "${view/token}");
          request.send(JSON.stringify({
            url: url,
            fileType: fileType,
            fileTitle: fileTitle,
            folderUID: selectedUIDs[0]
          }));

          if (request.status == 200) {
            var response = JSON.parse(request.response);
            docEditor.showMessage(saveAs.messages.success + " " + response.fileName);
          } else if (request.status == 403) {
            docEditor.showMessage(saveAs.messages.errorNotAuthorized);
          } else {
            docEditor.showMessage(saveAs.messages.errorUnknown);
          }

          saveAsDialog.hide();
        });
      };

      // Fired by the document server in response to docEditor.downloadAs().
      // event.data.url points to the file built from the *current* editor
      // state, so this downloads the document exactly as it is on screen.
      var onDownloadAs = function (event) {
        // 1) hand the freshly built file to the browser.
        var link = document.createElement("a");
        link.href = event.data.url;
        link.download = config.document.title || "";
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

        // 2) persist that same file to Plone so the downloaded version is also
        // stored on the server. Only when the session can be saved back.
        var canPersist = !!(config.editorConfig && config.editorConfig.callbackUrl);
        if (canPersist) {
          try {
            var request = new XMLHttpRequest();
            request.open("POST", "${context/absolute_url}/onlyoffice-save-current", true);
            request.setRequestHeader("x-csrf-token", "${view/token}");
            request.onload = function () {
              if (request.status === 200) {
                showOnlyofficeMessage(downloadMessages.saved);
              } else {
                showOnlyofficeMessage(downloadMessages.notSaved);
              }
            };
            request.onerror = function () {
              showOnlyofficeMessage(downloadMessages.notSaved);
            };
            request.send(JSON.stringify({ url: event.data.url }));
          } catch (e) {
            // Best effort: the download has already happened.
            showOnlyofficeMessage(downloadMessages.notSaved);
          }
        } else {
          showOnlyofficeMessage(downloadMessages.downloaded);
        }
      };

      var downloadMessages = {
        saved: "Document downloaded and saved to the server.",
        notSaved: "Document downloaded, but it could not be saved to the server.",
        downloaded: "Document downloaded."
      };

      function showOnlyofficeMessage(text) {
        if (typeof docEditor !== "undefined" && docEditor && docEditor.showMessage) {
          docEditor.showMessage(text);
        }
      }

      var renameMessages = {
        renamed: "File renamed.",
        notRenamed: "The file could not be renamed."
      };

      // Fired when the user renames the document in the editor. event.data is
      // the new name without extension; the server updates both the Plone Title
      // and the stored file name (keeping the extension).
      var onRequestRename = function (event) {
        var newName = event.data;
        if (!newName) { return; }
        try {
          var request = new XMLHttpRequest();
          request.open("POST", "${context/absolute_url}/onlyoffice-rename", true);
          request.setRequestHeader("x-csrf-token", "${view/token}");
          request.onload = function () {
            showOnlyofficeMessage(
              request.status === 200 ? renameMessages.renamed : renameMessages.notRenamed
            );
          };
          request.onerror = function () {
            showOnlyofficeMessage(renameMessages.notRenamed);
          };
          request.send(JSON.stringify({ name: newName }));
        } catch (e) {
          showOnlyofficeMessage(renameMessages.notRenamed);
        }
      };

      config.events = {
        "onAppReady": onAppReady,
        "onDownloadAs": onDownloadAs,
        "onRequestRename": onRequestRename,
        "onRequestInsertImage": onRequestInsertImage,
        "onRequestCompareFile": onRequestCompareFile,
        "onRequestMailMergeRecipients": onRequestMailMergeRecipients
      };


      if (saveAs.available) {
        config.events.onRequestSaveAs = onRequestSaveAs
      }

      // Called by the "Download" button. Asks the editor for the live document
      // (handled by onDownloadAs above). Falls back to the stored copy if the
      // editor has not loaded.
      function onlyofficeDownload() {
        if (typeof docEditor !== "undefined" && docEditor && docEditor.downloadAs) {
          docEditor.downloadAs();
        } else {
          window.location.href = "${context/absolute_url}/@@download/file";
        }
      }

      function initDocEditor() {
        if (typeof DocsAPI === "undefined") {
          document.getElementById("onlyofficeErrorNotAccessible").style.display = "block";
          return;
        }

        var docsVersion = DocsAPI.DocEditor.version().split(".");

        if (docsVersion[0] < 6 || docsVersion[0] == 6 && docsVersion[1] == 0) {
          document.getElementById("onlyofficeErrorNotSupportedVersion").style.display = "block";
          return;
        }

        if ((config.document.fileType === "docxf" || config.document.fileType === "oform")
          && docsVersion[0] < 7) {
          document.getElementById("onlyofficeErrorNotSupportedVersionForm").style.display = "block";
          return;
        }

        docEditor = new DocsAPI.DocEditor("onlyofficeEditor", config);
      }

      initDocEditor();
    </script>
  </metal:block>

</html>
