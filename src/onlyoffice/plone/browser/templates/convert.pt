  <head>
    <tal:javascript metal:fill-slot="javascript_head_slot">
      <script type="text/javascript"
              tal:attributes="
                src string:${portal_url}/++resource++onlyoffice-static/js/utils.js;
              "
      ></script>
      <script type="text/javascript"
              tal:attributes="
                src string:${portal_url}/++resource++onlyoffice-static/js/convert.js;
              "
      ></script>
    </tal:javascript>
    <metal:css fill-slot="style_slot">
      <style type="text/css">
        .field:not(.error) div.fieldErrorBox {
        display: inline-block;
        }

        .padding-none {
        padding: 0px !important;
        }

        .hide {
        display: none !important;
        }
      </style>
    </metal:css>
  </head>

  <body data-i18ncatalogurl="/plonejsi18n">

    <metal:main fill-slot="main">

      <div id="content-core">
        <h1 class="documentFirstHeading"
            tal:content="view/label"
        >Conversion in ONLYOFFICE</h1>

        <div id="content-core">
          <form metal:use-macro="context/@@ploneform-macros/titlelessform"></form>
        </div>

        <div class="formControls padding-none hide"
             id="progressBar"
        >
          <div class="upload-container">
            <div class="upload-queue">
              <div class="controls">
                <span id="messageProgress"></span>
                <div class="progress progress-striped active">
                  <div class="progress-bar progress-bar-success"
                       aria-valuemax="100"
                       aria-valuemin="0"
                       aria-valuenow="0"
                       role="progressbar"
                       style="width: 0%"
                  >
                    <span class="sr-only"
                          i18n:ignore=""
                    >100% Complete (success)</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <label class="hide"
               id="info"
               i18n:translate="Info"
        >Info</label>
        <label class="hide"
               id="error"
               i18n:translate="Error"
        >Error</label>
      </div>
    </metal:main>

  </body>
</html>
