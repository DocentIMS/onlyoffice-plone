<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Factory-based Type Information with dynamic views"
        name="File"
        i18n:domain="plone"
>
  <property name="view_methods"
            purge="False"
  >
    <element value="onlyoffice-view-file" />
    <element value="onlyoffice-open" />
  </property>
  <property name="default_view">onlyoffice-open</property>

  <action action_id="onlyoffice-edit"
          category="object_buttons"
          condition_expr="object/@@onlyoffice-edit/isAvailable"
          icon_expr="string:onlyoffice-logo"
          title="ONLYOFFICE Edit"
          url_expr="string:${object_url}/onlyoffice-edit"
          visible="True"
          i18n:attributes="title"
          i18n:domain="onlyoffice.plone"
  >
    <permission value="Modify portal content" />
  </action>

  <action action_id="onlyoffice-view"
          category="object_buttons"
          condition_expr="object/@@onlyoffice-view/canView"
          icon_expr="string:onlyoffice-logo"
          title="ONLYOFFICE View"
          url_expr="string:${object_url}/onlyoffice-view"
          visible="True"
          i18n:attributes="title"
          i18n:domain="onlyoffice.plone"
  >
    <permission value="View" />
  </action>

  <action action_id="onlyoffice-review"
          category="object_buttons"
          condition_expr="object/@@onlyoffice-review/canReview"
          icon_expr="string:onlyoffice-logo"
          title="ONLYOFFICE Review"
          url_expr="string:${object_url}/onlyoffice-review"
          visible="True"
          i18n:attributes="title"
          i18n:domain="onlyoffice.plone"
  >
    <permission value="View" />
  </action>

  <action action_id="onlyoffice-fill-form"
          category="object_buttons"
          condition_expr="object/@@onlyoffice-fill-form/isAvailable"
          icon_expr="string:onlyoffice-logo"
          title="Fill in form in ONLYOFFICE"
          url_expr="string:${object_url}/onlyoffice-fill-form"
          visible="True"
          i18n:attributes="title"
          i18n:domain="onlyoffice.plone"
  >
    <permission value="Modify portal content" />
  </action>

  <action action_id="onlyoffice-conversion-file"
          category="object_buttons"
          condition_expr="object/@@onlyoffice-convert-file/isAvailable"
          icon_expr="string:onlyoffice-logo"
          title="Conversion in ONLYOFFICE"
          url_expr="string:${object_url}/onlyoffice-convert-file"
          visible="True"
          i18n:attributes="title"
          i18n:domain="onlyoffice.plone"
  >
    <permission value="View" />
  </action>
</object>
