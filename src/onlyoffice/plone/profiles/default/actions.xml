<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Plone Actions Tool"
        name="portal_actions"
>
  <object meta_type="CMF Action Category"
          name="object_buttons"
  >
    <object meta_type="CMF Action"
            name="download-as-file"
            i18n:domain="onlyoffice.plone"
    >
      <property name="title"
                i18n:translate=""
      >Download as</property>
      <property name="description"
                i18n:translate=""
      />
      <property name="url_expr">string:$object_url/onlyoffice-download-as-file</property>
      <property name="icon_expr">string:onlyoffice-logo</property>
      <property name="available_expr">object/@@onlyoffice-download-as-file/isAvailable|nothing</property>
      <property name="permissions">
        <element value="View" />
      </property>
      <property name="visible">True</property>
      <property name="modal"
                type="text"
      >{}</property>
    </object>
    <object meta_type="CMF Action"
            name="download-as-document"
            i18n:domain="onlyoffice.plone"
    >
      <property name="title"
                i18n:translate=""
      >Download as</property>
      <property name="description"
                i18n:translate=""
      />
      <property name="url_expr">string:$object_url/onlyoffice-download-as-document</property>
      <property name="icon_expr">string:onlyoffice-logo</property>
      <property name="available_expr">object/@@onlyoffice-download-as-document/isAvailable|nothing</property>
      <property name="permissions">
        <element value="View" />
      </property>
      <property name="visible">True</property>
      <property name="modal"
                type="text"
      >{}</property>
    </object>
  </object>

  <!--
    Entries for collective.sidebar (and any theme that renders the
    'sidebar_links' action category). The standard Barceloneta theme does not
    render this category, so the existing "Create with ONLYOFFICE" toolbar menu
    is not duplicated there. The _authenticator token is embedded because the
    sidebar renders these links verbatim (it does not add a CSRF token itself)
    and onlyoffice-create writes content.
  -->
  <object meta_type="CMF Action Category"
          name="sidebar_links"
  >
    <object meta_type="CMF Action"
            name="onlyoffice-create-word"
            i18n:domain="onlyoffice.plone"
    >
      <property name="title"
                i18n:translate=""
      >Document</property>
      <property name="description"
                i18n:translate=""
      >Create a new document with ONLYOFFICE</property>
      <property name="url_expr">python:object.absolute_url() + '/onlyoffice-create?documentType=word&amp;_authenticator=' + object.restrictedTraverse('@@authenticator').token()</property>
      <property name="icon_expr">string:onlyoffice-file-word</property>
      <property name="available_expr">python:object.restrictedTraverse('@@plone_context_state').is_structural_folder()</property>
      <property name="permissions">
        <element value="Add portal content" />
      </property>
      <property name="visible">True</property>
    </object>
    <object meta_type="CMF Action"
            name="onlyoffice-create-cell"
            i18n:domain="onlyoffice.plone"
    >
      <property name="title"
                i18n:translate=""
      >Spreadsheet</property>
      <property name="description"
                i18n:translate=""
      >Create a new spreadsheet with ONLYOFFICE</property>
      <property name="url_expr">python:object.absolute_url() + '/onlyoffice-create?documentType=cell&amp;_authenticator=' + object.restrictedTraverse('@@authenticator').token()</property>
      <property name="icon_expr">string:onlyoffice-file-cell</property>
      <property name="available_expr">python:object.restrictedTraverse('@@plone_context_state').is_structural_folder()</property>
      <property name="permissions">
        <element value="Add portal content" />
      </property>
      <property name="visible">True</property>
    </object>
    <object meta_type="CMF Action"
            name="onlyoffice-create-slide"
            i18n:domain="onlyoffice.plone"
    >
      <property name="title"
                i18n:translate=""
      >Presentation</property>
      <property name="description"
                i18n:translate=""
      >Create a new presentation with ONLYOFFICE</property>
      <property name="url_expr">python:object.absolute_url() + '/onlyoffice-create?documentType=slide&amp;_authenticator=' + object.restrictedTraverse('@@authenticator').token()</property>
      <property name="icon_expr">string:onlyoffice-file-slide</property>
      <property name="available_expr">python:object.restrictedTraverse('@@plone_context_state').is_structural_folder()</property>
      <property name="permissions">
        <element value="Add portal content" />
      </property>
      <property name="visible">True</property>
    </object>
    <object meta_type="CMF Action"
            name="onlyoffice-create-form"
            i18n:domain="onlyoffice.plone"
    >
      <property name="title"
                i18n:translate=""
      >PDF form</property>
      <property name="description"
                i18n:translate=""
      >Create a new PDF form with ONLYOFFICE</property>
      <property name="url_expr">python:object.absolute_url() + '/onlyoffice-create?documentType=form&amp;_authenticator=' + object.restrictedTraverse('@@authenticator').token()</property>
      <property name="icon_expr">string:onlyoffice-file-form</property>
      <property name="available_expr">python:object.restrictedTraverse('@@plone_context_state').is_structural_folder()</property>
      <property name="permissions">
        <element value="Add portal content" />
      </property>
      <property name="visible">True</property>
    </object>
  </object>
</object>
