<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Plone Actions Tool"
        name="portal_actions"
>
  <object meta_type="CMF Action Category"
          name="object_buttons"
  >
    <object meta_type="CMF Action"
            name="download-as-file"
            i18n:domain="onlyoffice.plone"
    >
      <property name="title"
                i18n:translate=""
      >Download as</property>
      <property name="description"
                i18n:translate=""
      />
      <property name="url_expr">string:$object_url/onlyoffice-download-as-file</property>
      <property name="icon_expr">string:onlyoffice-logo</property>
      <property name="available_expr">object/@@onlyoffice-download-as-file/isAvailable|nothing</property>
      <property name="permissions">
        <element value="View" />
      </property>
      <property name="visible">True</property>
      <property name="modal"
                type="text"
      >{}</property>
    </object>
    <object meta_type="CMF Action"
            name="download-as-document"
            i18n:domain="onlyoffice.plone"
    >
      <property name="title"
                i18n:translate=""
      >Download as</property>
      <property name="description"
                i18n:translate=""
      />
      <property name="url_expr">string:$object_url/onlyoffice-download-as-document</property>
      <property name="icon_expr">string:onlyoffice-logo</property>
      <property name="available_expr">object/@@onlyoffice-download-as-document/isAvailable|nothing</property>
      <property name="permissions">
        <element value="View" />
      </property>
      <property name="visible">True</property>
      <property name="modal"
                type="text"
      >{}</property>
    </object>
  </object>
</object>
